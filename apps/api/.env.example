# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-secret-key-here

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (dev):      sqlite:///taskly.db
# PostgreSQL (prod): postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///taskly.db

# ── Email (Flask-Mail) ────────────────────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=b3njaminbaya@gmail.com

# ── Frontend ──────────────────────────────────────────────────────────────────
# Used for constructing password-reset links in emails
FRONTEND_URL=http://localhost:5173

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=another-secret-key-for-sessions

# ── Observability ─────────────────────────────────────────────────────────────
# Leave blank to disable Sentry error tracking
SENTRY_DSN=

# ── Redis (optional) ─────────────────────────────────────────────────────────
# When set, used for rate-limiter storage + Socket.IO multi-worker adapter
# Format: redis://user:password@host:6379/0
REDIS_URL=

