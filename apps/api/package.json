{
  "name": "@taskly/api",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "flask --app app run --debug --port 5000",
    "start": "gunicorn app:app --workers 4 --bind 0.0.0.0:5000",
    "lint": "flake8 app.py models.py views/ --max-line-length 120 --ignore E501,W503 || true",
    "test": "python -m pytest tests/ -v || true",
    "clean": "find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null; find . -name '*.pyc' -delete 2>/dev/null; exit 0"
  }
}
